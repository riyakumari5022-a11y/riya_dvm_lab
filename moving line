import numpy as np
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation

# Create figure and axis
fig, ax = plt.subplots()

x = np.linspace(0, 10, 100)
line, = ax.plot(x, np.sin(x), color='red')

ax.set_xlim(0, 10)
ax.set_ylim(-2, 2)
ax.set_title("Moving Line Animation")

# Update function
def update(frame):
    line.set_ydata(np.sin(x + frame / 5))  # Shift wave
    return line,

# Create animation
ani = FuncAnimation(
    fig,
    update,
    frames=200,
    interval=50,
    blit=True
)

plt.show()