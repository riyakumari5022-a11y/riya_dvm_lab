import numpy as np
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation

# Create figure
fig, ax = plt.subplots()
x = np.linspace(0, 4 * np.pi, 100)
line, = ax.plot(x, np.sin(x), color='blue')

ax.set_ylim(-1.5, 1.5)
ax.set_title("Animated Sine Wave")
ax.set_xlabel("X axis")
ax.set_ylabel("Y axis")

# Update function
def update(frame):
    line.set_ydata(np.sin(x + frame / 10))  # shift wave
    return line,

# Create animation
ani = FuncAnimation(
    fig,
    update,
    frames=200,
    interval=50,
    blit=True
)

plt.show()