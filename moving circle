import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation
import matplotlib.patches as patches

# Create figure and axis
fig, ax = plt.subplots()
ax.set_xlim(0, 10)
ax.set_ylim(0, 10)

# Create circle
circle = patches.Circle((0, 5), radius=0.5, color='blue')
ax.add_patch(circle)

# Update function
def update(frame):
    circle.center = (frame, 5)  # Move along x-axis
    return circle,

# Create animation
ani = FuncAnimation(
    fig,
    update,
    frames=range(0, 11),
    interval=100,
    blit=True
)

plt.gca().set_aspect('equal', adjustable='box')
plt.show()